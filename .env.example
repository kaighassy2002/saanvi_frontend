# ─── Goks Integration ────────────────────────────────────────────────────────
# Copy this to .env and fill in values

# Goks backend origin — no trailing slash
# In production: https://your-goks-backend.com
VITE_API_URL=http://localhost:8000

# Tenant slug registered in Goks (matches the store owner's slug field)
VITE_STORE_SLUG=

# Storefront access token — get from Goks → Settings → Storefront → Rotate Token.
# Required when the tenant has a token configured (enforced server-side).
VITE_STOREFRONT_KEY=

# Set to true in local dev to proxy /api through Vite (avoids CORS).
# Set to false in production — requests go directly to VITE_API_URL.
VITE_DEV_PROXY=true
