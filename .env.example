# jewellery_backend integration (see jewellery_backend/README.md)

# Set to true in local dev to proxy /api → http://localhost:5000 (see vite.config.js)
VITE_DEV_PROXY=true

# Full API origin without trailing slash — used when VITE_DEV_PROXY is not true (e.g. production build)
# VITE_API_URL=http://localhost:5000

# Prefix for browser localStorage keys when multiple storefronts share one origin
VITE_STORE_SLUG=aashmika-designs

# WhatsApp business number (digits only, with India country code 91, no + or spaces)
# VITE_STORE_WHATSAPP=919876543210

# Razorpay checkout key (public key id)
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
